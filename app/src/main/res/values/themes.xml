<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.CineFast"
        parent="Theme.Material3.DayNight.NoActionBar" />

    <!-- Main App Theme -->
    <style name="Theme.CineFast"
        parent="Base.Theme.CineFast" />

    <!-- Splash Theme -->
    <style name="Theme.CineFast.Splash"
        parent="Theme.SplashScreen">

        <!-- Black background -->
        <item name="windowSplashScreenBackground">
            @android:color/black
        </item>

        <!-- Center Logo -->
        <item name="windowSplashScreenAnimatedIcon">
            @drawable/splash_logo
        </item>

        <!-- After splash go to main theme -->
        <item name="postSplashScreenTheme">
            @style/Theme.CineFast
        </item>

    </style>

</resources>
