<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <!-- TOP HEADER SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_back_button"
            android:padding="8dp"
            android:layout_marginBottom="12dp"
            app:tint="#FFFFFF" />

        <!-- Movie Name -->
        <TextView
            android:id="@+id/tvMovieName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- Badges Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+13"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_green"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EN"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/bg_badge_dark"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ScreenX"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/bg_badge_dark"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>

        <!-- Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/round_add_location_24"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="3dp"
                        app:tint="#AAAAAA"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Theater"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stars (90°Mall)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/round_camera_roll_24"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="3dp"
                        app:tint="#AAAAAA"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hall"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1st"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/baseline_calendar_today_24"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="3dp"
                        app:tint="#AAAAAA"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="13.04.2025"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/baseline_access_time_filled_24"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="3dp"
                        app:tint="#AAAAAA"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22:15"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- MAIN DARK SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#111111">

        <!-- Screen arc indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="220dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_screen_arc"/>
        </LinearLayout>

        <!-- Seat Grid -->
        <GridLayout
            android:id="@+id/seatGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:columnCount="9"
            android:rowCount="5"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="true"
            android:padding="8dp"
            android:layout_gravity="center">

            <!-- ROW A: seats without visible text -->
            <TextView
                android:id="@+id/seat_a1"
                android:text=""
                android:tag="A1"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="0"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a2"
                android:text=""
                android:tag="A2"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="1"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a3"
                android:text=""
                android:tag="A3"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="2"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a4"
                android:text=""
                android:tag="A4"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="3"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a5"
                android:text=""
                android:tag="A5"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="4"
                android:layout_row="0"/>
            <!-- AISLE GAP col 5 -->
            <Space
                android:layout_width="20dp"
                android:layout_height="0dp"
                android:layout_column="5"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a6"
                android:text=""
                android:tag="A6"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="6"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a7"
                android:text=""
                android:tag="A7"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="7"
                android:layout_row="0"/>
            <TextView
                android:id="@+id/seat_a8"
                android:text=""
                android:tag="A8"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="8"
                android:layout_row="0"/>

            <!-- ROW B -->
            <TextView
                android:id="@+id/seat_b1"
                android:text=""
                android:tag="B1"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="0"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b2"
                android:text=""
                android:tag="B2"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="1"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b3"
                android:text=""
                android:tag="B3"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="2"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b4"
                android:text=""
                android:tag="B4"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="3"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b5"
                android:text=""
                android:tag="B5"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="4"
                android:layout_row="1"/>
            <Space
                android:layout_width="20dp"
                android:layout_height="0dp"
                android:layout_column="5"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b6"
                android:text=""
                android:tag="B6"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="6"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b7"
                android:text=""
                android:tag="B7"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="7"
                android:layout_row="1"/>
            <TextView
                android:id="@+id/seat_b8"
                android:text=""
                android:tag="B8"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="8"
                android:layout_row="1"/>

            <!-- ROW C -->
            <TextView
                android:id="@+id/seat_c1"
                android:text=""
                android:tag="C1"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="0"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c2"
                android:text=""
                android:tag="C2"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="1"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c3"
                android:text=""
                android:tag="C3"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="2"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c4"
                android:text=""
                android:tag="C4"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="3"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c5"
                android:text=""
                android:tag="C5"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="4"
                android:layout_row="2"/>
            <Space
                android:layout_width="20dp"
                android:layout_height="0dp"
                android:layout_column="5"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c6"
                android:text=""
                android:tag="C6"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="6"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c7"
                android:text=""
                android:tag="C7"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="7"
                android:layout_row="2"/>
            <TextView
                android:id="@+id/seat_c8"
                android:text=""
                android:tag="C8"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="8"
                android:layout_row="2"/>

            <!-- ROW D -->
            <TextView
                android:id="@+id/seat_d1"
                android:text=""
                android:tag="D1"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="0"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d2"
                android:text=""
                android:tag="D2"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="1"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d3"
                android:text=""
                android:tag="D3"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="2"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d4"
                android:text=""
                android:tag="D4"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="3"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d5"
                android:text=""
                android:tag="D5"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="4"
                android:layout_row="3"/>
            <Space
                android:layout_width="20dp"
                android:layout_height="0dp"
                android:layout_column="5"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d6"
                android:text=""
                android:tag="D6"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="6"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d7"
                android:text=""
                android:tag="D7"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="7"
                android:layout_row="3"/>
            <TextView
                android:id="@+id/seat_d8"
                android:text=""
                android:tag="D8"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="8"
                android:layout_row="3"/>

            <!-- ROW E -->
            <TextView
                android:id="@+id/seat_e1"
                android:text=""
                android:tag="E1"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="0"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e2"
                android:text=""
                android:tag="E2"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="1"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e3"
                android:text=""
                android:tag="E3"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="2"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e4"
                android:text=""
                android:tag="E4"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="3"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e5"
                android:text=""
                android:tag="E5"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="4"
                android:layout_row="4"/>
            <Space
                android:layout_width="20dp"
                android:layout_height="0dp"
                android:layout_column="5"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e6"
                android:text=""
                android:tag="E6"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="6"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e7"
                android:text=""
                android:tag="E7"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_booked"
                android:layout_column="7"
                android:layout_row="4"/>
            <TextView
                android:id="@+id/seat_e8"
                android:text=""
                android:tag="E8"
                style="@style/SeatStyle"
                android:background="@drawable/bg_seat_available"
                android:layout_column="8"
                android:layout_row="4"/>
        </GridLayout>

        <!-- Legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="24dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_legend_dot_booked"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booked"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="24dp">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_legend_dot_yours"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yours"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_legend_dot_available"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- BOTTOM BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="#111111">

        <Button
            android:id="@+id/btnBookSeats"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#E8352A"
            android:text="Book Seats"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            app:cornerRadius="26dp"/>

        <Button
            android:id="@+id/btnProceedToSnacks"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FFFFFF"
            android:text="Proceed to Snacks"
            android:textColor="#111111"
            android:textSize="13sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            app:cornerRadius="26dp"/>
    </LinearLayout>

</LinearLayout>